{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --port 3010",
    "dev:test": "nuxt dev --port 3011",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "lint": "eslint .",
    "postinstall": "nuxt prepare",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "emulator:start": "firebase emulators:start --project demo-test --only auth,firestore",
    "deploy": "npm run test:e2e && bash deploy.sh"
  },
  "dependencies": {
    "@internationalized/date": "^3.8.2",
    "@nuxt/eslint": "^1.3.0",
    "@nuxt/icon": "^1.12.0",
    "@nuxt/image": "^1.10.0",
    "@nuxt/ui": "^3.0.2",
    "@tailwindcss/vite": "^4.1.6",
    "@unhead/vue": "^2.0.8",
    "@vite-pwa/nuxt": "^1.0.4",
    "chart.js": "^4.5.0",
    "eslint": "^9.25.1",
    "firebase": "^11.9.1",
    "nuxt": "^3.16.2",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1.6",
    "typescript": "^5.8.3",
    "vue": "^3.5.13",
    "vue-chartjs": "^5.3.2",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "sass": "^1.87.0"
  }
}

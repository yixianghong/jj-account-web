{
    "hosting": {
        "public": ".output/public",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "**",
                "destination": "/index.html"
            }
        ]
    },
    "functions": {
        "source": "functions"
    },
    "emulators": {
        "auth": { "port": 9099 },
        "firestore": { "port": 8080 },
        "ui": { "enabled": true, "port": 4000 }
    }
}
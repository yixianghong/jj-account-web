# Firebase Web App 設定（從 Firebase Console > 專案設定 > 您的應用程式取得）
# 本機開發：複製本檔為 .env 並填入實際值
# CI/CD：同名設為 GitHub Repository Secrets（見 .github/workflows/firebase-deploy.yml）
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
# Web Push 憑證金鑰（Firebase Console > 專案設定 > Cloud Messaging > 網頁推送憑證）
FIREBASE_VAPID_KEY=

# 設為 true 時連線本機 Firebase emulator（一般本機開發不需要）
# NUXT_PUBLIC_USE_EMULATOR=true
